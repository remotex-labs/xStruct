{
    "name": "@remotex-labs/xstruct",
    "main": "dist/cjs/index.js",
    "type": "module",
    "types": "./dist/index.d.ts",
    "module": "./dist/esm/index.js",
    "author": "Garefild",
    "version": "1.0.0-local",
    "license": "Mozilla Public License Version 2.0",
    "homepage": "https://remotex-labs.github.io/xStruct",
    "description": "This library provides a simple way to define and serialize data structures (structs) with support for both regular fields and bitfields",
    "sideEffects": false,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/remotex-labs/xStruct.git"
    },
    "bugs": {
        "url": "https://github.com/remotex-labs/xStruct/issues"
    },
    "keywords": [
        "xStruct",
        "xstruct",
        "struct",
        "bit struct",
        "typescript",
        "formatter",
        "CLI",
        "javascript",
        "developer-tools"
    ],
    "engines": {
        "node": ">=20"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js"
        }
    },
    "files": [
        "dist",
        "LICENSE",
        "README.md"
    ],
    "scripts": {
        "dev":              "xBuild -w",
        "build":            "xBuild",
        "build:clean":      "rm -rf ./dist && xBuild",

        "test":             "xjet",
        "test:coverage":    "xjet --coverage",

        "lint":             "pnpm lint:md && pnpm lint:eslint && pnpm lint:typescript",
        "lint:md":          "markdownlint \"**/*.md\" --ignore node_modules",
        "lint:eslint":      "eslint . -c ./eslint.config.mjs",
        "lint:typescript":  "xBuild --tc",

        "docs:dev":         "vitepress dev docs",
        "docs:build":       "vitepress build docs",
        "docs:preview":     "vitepress preview docs",

        "ci":              "pnpm lint && pnpm test && pnpm build:clean",
        "prepublishOnly":  "pnpm build:clean && pnpm lint && pnpm test"
    },
    "devDependencies": {
        "eslint": "^10.1.0",
        "vitepress": "^2.0.0-alpha.15",
        "markdownlint-cli": "^0.48.0",
        "typescript-eslint": "^8.57.1",
        "eslint-plugin-tsdoc": "^0.5.0",
        "eslint-plugin-perfectionist": "^5.7.0",
        "@types/node": "^25.5.0",
        "@remotex-labs/xjet": "^1.5.4",
        "@viteplus/versions": "^2.0.6",
        "@remotex-labs/xbuild": "^2.2.4"
    }
}
